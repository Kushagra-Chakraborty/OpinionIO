FROM python:3.12-slim

WORKDIR /app

# Copy requirements first (for better caching)
COPY Models/XGBoost/requirements-xgboost.txt .

# Install dependencies
RUN pip install --no-cache-dir -r requirements-xgboost.txt

# Copy only the shared General module
COPY General/ ./General/

# Copy only this specific model
COPY Models/__init__.py ./Models/
COPY Models/kafka_helper/ ./Models/kafka_helper/
COPY Models/XGBoost/ ./Models/XGBoost/

# Set Python path so imports work
ENV PYTHONPATH=/app

# Model artifacts will be mounted as a volume at /app/Models/models
VOLUME ["/app/Models/models"]

CMD ["fastkafka", "run", "--num-workers", "2", "Models.XGBoost.main:kafka_app"]
