FROM python:3.12-slim

WORKDIR /app

# Copy requirements first (for better caching)
COPY Models/TinyBert/requirements-tinybert.txt .

# Install dependencies (torch-cpu only from PyTorch CPU index)
# Install dependencies (torch-cpu from PyTorch CPU index, others from PyPI)
RUN pip install --no-cache-dir --extra-index-url https://download.pytorch.org/whl/cpu -r requirements-tinybert.txt
# Copy only the shared General module
COPY General/ ./General/

# Copy only this specific model
COPY Models/__init__.py ./Models/
COPY Models/kafka_helper/ ./Models/kafka_helper/
COPY Models/TinyBert/ ./Models/TinyBert/

# Set Python path so imports work
ENV PYTHONPATH=/app

# Model artifacts will be mounted as a volume at /app/Models/models
VOLUME ["/app/Models/models"]

CMD ["fastkafka", "run", "--num-workers", "2", "Models.TinyBert.main:kafka_app"]
