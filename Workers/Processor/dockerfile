FROM python:3.12-slim

WORKDIR /app

# Copy requirements first (for better caching)
COPY Workers/Processor/requirements-processor.txt .

# Install dependencies
RUN pip install --no-cache-dir -r requirements-processor.txt

# Copy only the shared General module
COPY General/ ./General/

# Copy only this specific worker
COPY Workers/__init__.py ./Workers/
COPY Workers/send_status.py ./Workers/
COPY Workers/Processor/ ./Workers/Processor/

# Set Python path so imports work
ENV PYTHONPATH=/app

CMD ["fastkafka", "run", "--num-workers", "2", "Workers.Processor.main:kafka_app"]
